# Dependencies
node_modules/
.pnpm-store/

# Production
dist/
build/

# Local env files
.env
.env.local

# Logs
npm-debug.log*
yarn-debug.log*

# User requested exclusions (videos, images, pdfs)
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.webp
*.jpg
*.jpeg
*.png
*.gif
*.pdf

# Allow project demo screenshots in docs/screenshots/
!docs/screenshots/
!docs/screenshots/*.png

